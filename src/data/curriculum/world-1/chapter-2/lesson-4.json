  "grammarSpotlight": {
    "ruleId": "gr-einai-3rd-001",
    "title": { "en": "He/She/It Is: Αυτός/Αυτή/Αυτό είναι", "sv": "Han/Hon/Det är: Αυτός/Αυτή/Αυτό είναι" },
    "explanation": {
      "en": "Now you know THREE forms! Είμαι (I am), Είσαι (you are), and now Είναι (he/she/it is). Notice: αυτός = he/this (masculine), αυτή = she/this (feminine), αυτό = it/this (neuter). Also: φίλος = male friend, φίλη = female friend — Greek marks gender!",
      "sv": "Nu kan du TRE former! Είμαι (jag är), Είσαι (du är), och nu Είναι (han/hon/det är). Observera: αυτός = han/den här (maskulinum), αυτή = hon/den här (femininum), αυτό = det/det här (neutrum). Dessutom: φίλος = manlig vän, φίλη = kvinnlig vän — grekiska markerar kön!"
    },
    "buildingBlocks": [
      { "step": 1, "instruction": { "en": "He is / This is (masculine)", "sv": "Han är / Det här är (maskulinum)" }, "greek": "Αυτός είναι", "translation": { "en": "He is / This is", "sv": "Han är / Det här är" } },
      { "step": 2, "instruction": { "en": "She is / This is (feminine)", "sv": "Hon är / Det här är (femininum)" }, "greek": "Αυτή είναι", "translation": { "en": "She is / This is", "sv": "Hon är / Det här är" } },
      { "step": 3, "instruction": { "en": "It is / This is (neuter)", "sv": "Det är / Det här är (neutrum)" }, "greek": "Αυτό είναι", "translation": { "en": "It is / This is", "sv": "Det är / Det här är" } },
      { "step": 4, "instruction": { "en": "Male friend", "sv": "Manlig vän" }, "greek": "φίλος", "translation": { "en": "friend (male)", "sv": "vän (man)" } },
      { "step": 5, "instruction": { "en": "Female friend", "sv": "Kvinnlig vän" }, "greek": "φίλη", "translation": { "en": "friend (female)", "sv": "vän (kvinna)" } }
    ],
