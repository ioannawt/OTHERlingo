  "grammarSpotlight": {
    "ruleId": "gr-apo-pou-001",
    "title": { "en": "Where Are You From?: Από πού είσαι;", "sv": "Var kommer du ifrån?: Από πού είσαι;" },
    "explanation": {
      "en": "To ask where someone is from: Από πού είσαι; (apo PU I-seh). Από = from. Πού = where. To answer: Είμαι από + country. Notice: some countries use τη (τη Σουηδία) and others use την (την Ελλάδα, την Αγγλία) before the name — don't worry about this yet, just learn the phrases!",
      "sv": "För att fråga var någon kommer ifrån: Από πού είσαι; (apo PU I-seh). Από = från. Πού = var. Svara: Είμαι από + land. Observera: vissa länder använder τη (τη Σουηδία) och andra την (την Ελλάδα, την Αγγλία) före namnet — oroa dig inte om detta nu, lär dig bara fraserna!"
    },
    "buildingBlocks": [
      { "step": 1, "instruction": { "en": "From", "sv": "Från" }, "greek": "Από", "translation": { "en": "From", "sv": "Från" } },
      { "step": 2, "instruction": { "en": "Where?", "sv": "Var?" }, "greek": "Πού;", "translation": { "en": "Where?", "sv": "Var?" } },
      { "step": 3, "instruction": { "en": "Where are you from?", "sv": "Var kommer du ifrån?" }, "greek": "Από πού είσαι;", "translation": { "en": "Where are you from?", "sv": "Var kommer du ifrån?" } },
      { "step": 4, "instruction": { "en": "I am from Sweden", "sv": "Jag är från Sverige" }, "greek": "Είμαι από τη Σουηδία.", "translation": { "en": "I am from Sweden.", "sv": "Jag är från Sverige." } },
      { "step": 5, "instruction": { "en": "I am from Greece", "sv": "Jag är från Grekland" }, "greek": "Είμαι από την Ελλάδα.", "translation": { "en": "I am from Greece.", "sv": "Jag är från Grekland." } }
    ],
