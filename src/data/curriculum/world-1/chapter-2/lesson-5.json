  "grammarSpotlight": {
    "ruleId": "gr-pos-eisai-001",
    "title": { "en": "How Are You?: Πώς είσαι; + Negation with Δεν", "sv": "Hur mår du?: Πώς είσαι; + Negation med Δεν" },
    "explanation": {
      "en": "To ask 'How are you?': Πώς είσαι; Answers: Είμαι καλά (I'm well), Είμαι πολύ καλά (I'm very well), Έτσι κι έτσι (so-so). To say 'not': put δεν before the verb. Δεν είμαι καλά = I'm not well. Simple!",
      "sv": "För att fråga 'Hur mår du?': Πώς είσαι; Svar: Είμαι καλά (jag mår bra), Είμαι πολύ καλά (jag mår mycket bra), Έτσι κι έτσι (sådär). För att säga 'inte': sätt δεν före verbet. Δεν είμαι καλά = Jag mår inte bra. Enkelt!"
    },
    "buildingBlocks": [
      { "step": 1, "instruction": { "en": "How are you?", "sv": "Hur mår du?" }, "greek": "Πώς είσαι;", "translation": { "en": "How are you?", "sv": "Hur mår du?" } },
      { "step": 2, "instruction": { "en": "I'm well", "sv": "Jag mår bra" }, "greek": "Είμαι καλά.", "translation": { "en": "I'm well.", "sv": "Jag mår bra." } },
      { "step": 3, "instruction": { "en": "I'm very well", "sv": "Jag mår mycket bra" }, "greek": "Είμαι πολύ καλά.", "translation": { "en": "I'm very well.", "sv": "Jag mår mycket bra." } },
      { "step": 4, "instruction": { "en": "So-so", "sv": "Sådär" }, "greek": "Έτσι κι έτσι.", "translation": { "en": "So-so.", "sv": "Sådär." } },
      { "step": 5, "instruction": { "en": "I'm not well (δεν = not)", "sv": "Jag mår inte bra (δεν = inte)" }, "greek": "Δεν είμαι καλά.", "translation": { "en": "I'm not well.", "sv": "Jag mår inte bra." } }
    ],
    "examples": [
